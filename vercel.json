{
  "fluid": true,
  "experimentalServices": {
    "frontend": {
      "framework": "vite",
      "entrypoint": "frontend",
      "routePrefix": "/"
    },
    "backend": {
      "framework": "fastapi",
      "entrypoint": "backend/app/server.py",
      "routePrefix": "/api"
    },
    "agent": {
      "type": "worker",
      "entrypoint": "backend/app/worker.py",
      "topics": ["__wkf_*"]
    }
  }
}
